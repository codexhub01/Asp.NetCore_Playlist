@model Asp.NetCore_Playlist.Models.Employee
<form asp-action="Create" method="post">

    <label>Name</label>
    <input asp-for="Name" />
    <br />

    <label>Email</label>
    <input asp-for="Email" />
    <br />

    <label>Department</label>
    <input asp-for="Department" />
    <br />

    <label>Address</label>
    <input asp-for="Address" />
    <br />

    <label>Org Name</label>
    <input asp-for="OrgName" />
    <br />

    <button type="submit">Save</button>

</form>